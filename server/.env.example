# Copy to .env and fill in.

# MongoDB connection string (MongoDB Atlas free tier works great).
MONGODB_URI=mongodb://127.0.0.1:27017/quote-compass

# Port the Express API listens on.
PORT=4000

# Comma-separated list of allowed origins for CORS (the deployed frontend URL).
# Leave empty to allow all origins (fine for local dev / public demo).
CORS_ORIGIN=

# OPTIONAL server-side fallback Anthropic API key.
# The app is designed as "bring your own key": the frontend sends the user's key
# per request. This is only a fallback for local testing and should stay empty
# in the public demo so visitors always use their own key.
ANTHROPIC_API_KEY=
